{
  "name": "@qest/mcp-redact-proxy",
  "version": "0.1.0",
  "description": "Stdio proxy that sits in front of any MCP server and redacts PII/secrets from tool-call responses before they reach the LLM.",
  "type": "module",
  "bin": {
    "mcp-redact-proxy": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "yarn build"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "MIT"
}
